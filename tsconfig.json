{
  "compilerOptions": {
    "target": "ESNext",
    "module": "CommonJS",
    "lib": ["ESNext", "DOM"],
    "strict": true,
    "esModuleInterop": true,
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": ["@playwright/test", "node"]
  },
  "include": ["tests/**/*.ts", "src/**/*.ts", "playwright.config.ts"]
}
